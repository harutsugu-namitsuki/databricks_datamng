@startuml
title 国別の売上ランキング\n(3-6_sample_query_01_sales_by_country)

start

partition "データソース読み込み" {

fork
  :silver.orders (o)\n注文データ;
fork again
  :silver.customers (c)\n顧客データ;
fork again
  :silver.order_details (od)\n注文明細データ;
end fork

}

partition "JOIN" {
:orders JOIN customers\nON o.customer_id = c.customer_id;
:結果 JOIN order_details\nON o.order_id = od.order_id;

}

partition "集計" {
:GROUP BY c.country\n(国別に集約);

}

partition "計算カラム" {
note right
  * country: 顧客の国名
  * total_sales: SUM(単価 x 数量 x (1 - 割引率))  ROUND 2桁
  * order_count: COUNT(DISTINCT order_id)
end note

}

partition "ソート" {
:ORDER BY total_sales DESC\n(売上金額の降順);

:結果出力;

}

stop

@enduml
